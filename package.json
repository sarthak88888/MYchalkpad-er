{
  "name": "mychalkpad-erp",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "seed": "node scripts/seed-firestore.js",
    "assets": "node scripts/generate-assets.js",
    "build:apk": "eas build --platform android --profile production-apk",
    "build:aab": "eas build --platform android --profile production-aab",
    "build:ios": "eas build --platform ios --profile production-ios",
    "build:preview": "eas build --platform android --profile preview",
    "submit:android": "eas submit --platform android --profile production-aab",
    "submit:ios": "eas submit --platform ios --profile production-ios",
    "typecheck": "npx tsc --noEmit",
    "lint": "npx expo lint"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "1.23.1",
    "@sentry/react-native": "~6.10.0",
    "axios": "^1.6.2",
    "date-fns": "^3.0.0",
    "expo": "~52.0.0",
    "expo-build-properties": "~0.13.3",
    "expo-constants": "~17.0.8",
    "expo-document-picker": "~13.0.0",
    "expo-font": "~13.0.4",
    "expo-linking": "~7.0.5",
    "expo-local-authentication": "~15.0.2",
    "expo-location": "~18.0.0",
    "expo-router": "~4.0.22",
    "expo-secure-store": "~14.0.1",
    "expo-splash-screen": "~0.29.24",
    "expo-status-bar": "~2.0.1",
    "expo-updates": "~0.27.5",
    "firebase": "^10.7.1",
    "i18n-js": "^4.3.2",
    "papaparse": "^5.4.1",
    "react": "18.3.1",
    "react-native": "0.76.9",
    "react-native-paper": "^5.11.0",
    "react-native-qrcode-svg": "^6.2.0",
    "react-native-razorpay": "^2.2.3",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-svg": "15.8.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/react": "~18.3.0",
    "@types/papaparse": "^5.3.14",
    "typescript": "^5.1.3"
  },
  "private": true
}
